/* pages/parent/parent.wxss */

.container {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 入口区域 */
.entry-section {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.lock-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 60rpx;
}

.verify-btn {
  width: 400rpx;
  height: 88rpx;
  background: #FFFFFF;
  color: #667eea;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.verify-btn::after {
  border: none;
}

/* 控制面板 */
.panel-section {
  padding: 32rpx;
}

/* 用户信息卡片 */
.user-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.grade {
  font-size: 28rpx;
  color: #999;
}

.edit-btn {
  background: #F5F5F5;
  color: #666;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  border: none;
}

.edit-btn::after {
  border: none;
}

/* 区域卡片 */
.section-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.section-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-icon {
  font-size: 44rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.expand-icon {
  font-size: 24rpx;
  color: #999;
}

.section-content {
  padding: 24rpx;
}

/* 学习报告 */
.report-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90E2;
}

.report-chart {
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.chart-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  text-align: center;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 120rpx;
}

.bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.bar-fill {
  width: 40rpx;
  background: linear-gradient(180deg, #4A90E2, #357ABD);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 8rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
}

.detail-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.detail-btn::after {
  border: none;
}

/* 内容设置 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 32rpx;
  color: #333;
}

.setting-picker {
  flex: 1;
  text-align: right;
}

.picker-text {
  font-size: 30rpx;
  color: #4A90E2;
}

.subject-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.subject-tag {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  color: #666;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.subject-tag.selected {
  background: #E3F2FD;
  color: #4A90E2;
}

.save-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  margin-top: 24rpx;
}

.save-btn::after {
  border: none;
}

/* 监督功能 */
.monitor-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.monitor-item:last-child {
  margin-bottom: 0;
}

.monitor-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.monitor-icon {
  font-size: 48rpx;
}

.monitor-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.monitor-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.monitor-desc {
  font-size: 24rpx;
  color: #999;
}

.monitor-badge {
  background: #F5222D;
  color: #FFFFFF;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  min-width: 32rpx;
  text-align: center;
}

.monitor-arrow {
  font-size: 28rpx;
  color: #C0C0C0;
}

/* 退出按钮 */
.exit-btn {
  width: calc(100% - 64rpx);
  height: 88rpx;
  background: #FFFFFF;
  color: #F5222D;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: 2rpx solid #F5222D;
  margin: 24rpx 32rpx;
}

.exit-btn::after {
  border: none;
}

.exit-btn:active {
  background: #FFEBEE;
}
