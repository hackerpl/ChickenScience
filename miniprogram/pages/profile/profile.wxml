<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info-row">
      <view class="avatar">{{userInfo.nickname ? userInfo.nickname.charAt(0) : '👤'}}</view>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickname || '科学小达人'}}</text>
        <view class="vip-info">
          <text class="vip-badge">VIP {{userInfo.vip_level || 1}}</text>
          <text class="max-vip" wx:if="{{userInfo.max_vip_level > userInfo.vip_level}}">
            历史最高: VIP{{userInfo.max_vip_level}}
          </text>
        </view>
      </view>
    </view>

    <view class="user-actions">
      <view class="grade-display" bindtap="editGrade">
        <text class="grade-value">{{userInfo.grade || '小学四年级'}}</text>
        <text class="edit-icon">✏️</text>
      </view>
      <button class="parent-btn" bindtap="goToParent">
        👨‍👩‍👧 家长
      </button>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-value">{{userInfo.coins || 0}}</text>
      <text class="stat-label">金币</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{studyData.totalQuestions || 0}}</text>
      <text class="stat-label">答题数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{studyData.correctRate || 0}}%</text>
      <text class="stat-label">正确率</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <text class="section-title">我的</text>

    <view class="menu-list">
      <!-- 新手指引归档 -->
      <view class="menu-item" bindtap="viewGuide" wx:if="{{guideStatus === 'fast'}}">
        <view class="menu-left">
          <text class="menu-icon">📖</text>
          <text class="menu-text">新手指引</text>
          <text class="menu-tip">未认真阅读</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <!-- 好友系统（VIP10） -->
      <view class="menu-item" bindtap="goToFriends" wx:if="{{userInfo.vip_level >= 10}}">
        <view class="menu-left">
          <text class="menu-icon">👥</text>
          <text class="menu-text">我的好友</text>
        </view>
        <view class="menu-right">
          <text class="menu-badge">{{friendCount}}</text>
          <text class="menu-arrow">></text>
        </view>
      </view>

      <!-- 聊天记录（VIP10） -->
      <view class="menu-item" bindtap="goToChat" wx:if="{{userInfo.vip_level >= 10}}">
        <view class="menu-left">
          <text class="menu-icon">💬</text>
          <text class="menu-text">聊天记录</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <!-- 成就系统 -->
      <view class="menu-item" bindtap="goToAchievements">
        <view class="menu-left">
          <text class="menu-icon">🏆</text>
          <text class="menu-text">我的成就</text>
        </view>
        <view class="menu-right">
          <text class="menu-badge">{{achievementCount}}/20</text>
          <text class="menu-arrow">></text>
        </view>
      </view>

      <!-- 学习报告 -->
      <view class="menu-item" bindtap="goToReport">
        <view class="menu-left">
          <text class="menu-icon">📊</text>
          <text class="menu-text">学习报告</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <!-- 我的物品 -->
      <view class="menu-item" bindtap="goToItems">
        <view class="menu-left">
          <text class="menu-icon">🎁</text>
          <text class="menu-text">我的物品</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 设置区域 -->
  <view class="menu-section">
    <text class="section-title">设置</text>

    <view class="menu-list">
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-left">
          <text class="menu-icon">⚙️</text>
          <text class="menu-text">系统设置</text>
        </view>
        <text class="menu-arrow">></text>
      </view>

      <view class="menu-item" bindtap="showAbout">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于我们</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <button class="logout-btn" bindtap="logout">
    退出登录
  </button>
</view>
