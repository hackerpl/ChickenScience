/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.user-info-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.vip-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.vip-badge {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #FFFFFF;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.max-vip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.grade-display {
  flex: 2;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 56rpx;
}

.grade-display:active {
  background: rgba(255, 255, 255, 0.3);
}

.grade-value {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.edit-icon {
  font-size: 26rpx;
}

.parent-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.parent-btn::after {
  border: none;
}

.parent-btn::after {
  border: none;
}

/* 数据统计 */
.stats-section {
  display: flex;
  background: #FFFFFF;
  margin: 24rpx 32rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90E2;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
}

/* 菜单区域 */
.menu-section {
  margin: 24rpx 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F5F5F5;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  font-size: 44rpx;
}

.menu-text {
  font-size: 32rpx;
  color: #333;
}

.menu-tip {
  font-size: 24rpx;
  color: #FAAD14;
  margin-left: 8rpx;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.menu-badge {
  background: #F5222D;
  color: #FFFFFF;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  min-width: 32rpx;
  text-align: center;
}

.menu-arrow {
  font-size: 28rpx;
  color: #C0C0C0;
}

/* 退出登录 */
.logout-btn {
  margin: 40rpx 32rpx;
  height: 88rpx;
  background: #FFFFFF;
  color: #F5222D;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: 2rpx solid #F5222D;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background: #FFEBEE;
}
