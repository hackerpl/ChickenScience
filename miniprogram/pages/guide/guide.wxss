/* pages/guide/guide.wxss */

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
}

/* 标题栏 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.header .title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header .subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 内容区域 */
.content {
  flex: 1;
  padding: 32rpx;
}

.content-inner {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx;
  min-height: 60vh;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.guide-page {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.page-content {
  margin-bottom: 40rpx;
}

.page-content .text {
  font-size: 32rpx;
  line-height: 1.8;
  color: #555;
  display: block;
}

/* 示例区域 */
.example {
  background: #F0F8FF;
  border-left: 4rpx solid #4A90E2;
  padding: 24rpx;
  border-radius: 8rpx;
}

.example-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #4A90E2;
  margin-bottom: 12rpx;
}

.example-text {
  display: block;
  font-size: 30rpx;
  color: #666;
  line-height: 1.6;
}

/* 底部导航 */
.footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.nav-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.nav-btn::after {
  border: none;
}

.prev-btn {
  background: #F5F5F5;
  color: #666;
}

.next-btn {
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #FFFFFF;
}

.next-btn:active {
  opacity: 0.8;
}

/* 快速翻页提示 */
.fast-scroll-tip {
  position: fixed;
  left: 24rpx;
  bottom: 150rpx;
  background: rgba(245, 34, 45, 0.9);
  color: #FFFFFF;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  animation: shake 0.5s ease;
  z-index: 100;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10rpx); }
  75% { transform: translateX(10rpx); }
}
