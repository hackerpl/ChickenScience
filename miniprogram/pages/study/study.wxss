/* pages/study/study.wxss */

.container {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 用户信息栏 */
.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.vip-badge {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #FFFFFF;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.coin-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.coin-icon {
  font-size: 36rpx;
}

.coin-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FAAD14;
}

/* 模式选择区域 */
.mode-section {
  padding: 32rpx;
}

.section-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.mode-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.mode-card:active {
  transform: scale(0.98);
}

.mode-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.mode-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.mode-desc {
  font-size: 28rpx;
  color: #999;
}

.mode-card.challenge {
  background: linear-gradient(135deg, #FFECD2, #FCB69F);
}

/* 答题区域 */
.quiz-section {
  padding: 32rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90E2, #357ABD);
  transition: width 0.3s ease;
}

.progress-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 24rpx;
}

/* 题目卡片 */
.question-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.question-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.subject-tag {
  background: #E3F2FD;
  color: #4A90E2;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.difficulty-tag {
  background: #FFF3E0;
  color: #FF9800;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.question-text {
  display: block;
  font-size: 36rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 40rpx;
  font-weight: 500;
}

/* 选项按钮 */
.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.option-btn::after {
  border: none;
}

.option-btn.selected {
  background: #E3F2FD;
  border-color: #4A90E2;
  color: #4A90E2;
}

.option-btn.correct {
  background: #E8F5E9;
  border-color: #52C41A;
  color: #52C41A;
}

.option-btn.wrong {
  background: #FFEBEE;
  border-color: #F5222D;
  color: #F5222D;
}

/* 填空题输入 */
.fill-blank {
  margin-top: 20rpx;
}

.fill-input {
  width: 100%;
  height: 100rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.fill-input:focus {
  background: #FFFFFF;
  border-color: #4A90E2;
}

/* 答案结果 */
.result-section {
  margin-top: 32rpx;
}

.result-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.result-message text {
  display: block;
  text-align: center;
}

.result-message.correct {
  background: #E8F5E9;
  color: #52C41A;
}

.result-message.wrong {
  background: #FFEBEE;
  color: #F5222D;
}

.wrong-count {
  font-size: 26rpx;
  margin-top: 8rpx;
  opacity: 0.8;
}

.next-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.next-btn::after {
  border: none;
}

/* 提交按钮 */
.submit-section {
  margin-top: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: #E0E0E0;
  color: #999;
}

/* 视频弹窗 */
.video-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
}

.modal-header {
  margin-bottom: 24rpx;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-align: center;
  margin-bottom: 8rpx;
}

.modal-tip {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
}

.video-player {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background: #000;
}

.continue-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-top: 24rpx;
}

.continue-btn::after {
  border: none;
}

/* 完成弹窗 */
.complete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.complete-modal .modal-content {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 85%;
  max-width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.complete-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.complete-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.complete-stats {
  width: 100%;
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90E2;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.back-btn::after {
  border: none;
}
