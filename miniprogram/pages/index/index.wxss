/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 160rpx;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 64rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.app-slogan {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 身份选择区域 */
.identity-section {
  width: 100%;
  max-width: 600rpx;
}

.question {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-align: center;
  margin-bottom: 60rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.options {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.option-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.option-btn::after {
  border: none;
}

.option-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.option-btn .icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.option-btn .text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.option-btn .desc {
  font-size: 26rpx;
  color: #999;
}

.master-btn {
  background: linear-gradient(135deg, #FFECD2, #FCB69F);
}

.beginner-btn {
  background: linear-gradient(135deg, #A8EDEA, #FED6E3);
}

/* 加载中状态 */
.loading-section {
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading-text {
  font-size: 32rpx;
  color: #FFFFFF;
}
